# Backend HTTP port
PORT=3000

# Kubo/IPFS HTTP API endpoint. Kubo defaults to http://127.0.0.1:5001.
KUBO_API_URL=http://127.0.0.1:5001

# Allowed browser origins. Use comma-separated values for multiple origins.
CORS_ORIGIN=http://localhost:4200

# Express JSON body limit.
REQUEST_SIZE_LIMIT=64kb

# Basic content guards.
MAX_TITLE_LENGTH=200
MAX_BODY_LENGTH=50000
